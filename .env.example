# LLM configuration
LLM_MODEL=mimo-v2.5-pro
LLM_API_KEY=replace-with-your-api-key
LLM_BASE_URL=https://api.example.com/v1
LLM_TEMPERATURE=0.7
LLM_MAX_COMPLETION_TOKENS=2048
LLM_TIMEOUT=30

# Set to true only if your OpenAI-compatible endpoint must use HTTP_PROXY/HTTPS_PROXY.
LLM_TRUST_ENV=false
LLM_STREAMING=true

# Hugging Face mirror used by the one-shot model downloader.
HF_ENDPOINT=https://hf-mirror.com

# Long-term memory
QDRANT_COLLECTION=agent_memories

# Docker Compose wires Qdrant, the embedding service, and PostgreSQL
# automatically. You usually do not need to set their internal URLs here.
# Optional advanced vars such as QDRANT_API_KEY, QDRANT_PREFER_GRPC,
# EMBEDDING_CONCURRENCY, or EMBEDDING_BATCH_SIZE can be added manually.

# Embedding behavior
EMBEDDING_MODEL_SOURCE=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_TIMEOUT=30
EMBEDDING_TRUST_ENV=false

# Chainlit authentication
CHAINLIT_AUTH_SECRET=your-generated-secret
CHAINLIT_AUTH_USERNAME=admin
CHAINLIT_AUTH_PASSWORD=change-this-password
CHAINLIT_AUTH_USER_ID=wenhao
LANGGRAPH_STRICT_MSGPACK=true

# Conversation context window
CONVERSATION_MESSAGE_WINDOW=20

# App defaults
APP_DEBUG=false

# Docker image user. Keep 1000 on most Linux machines, or set these to
# the output of `id -u` and `id -g` before building the image.
APP_UID=1000
APP_GID=1000
