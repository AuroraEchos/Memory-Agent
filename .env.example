# LLM configuration
LLM_MODEL=mimo-v2.5-pro
LLM_API_KEY=replace-with-your-api-key
LLM_BASE_URL=https://api.example.com/v1
LLM_TEMPERATURE=0.7
LLM_MAX_COMPLETION_TOKENS=2048
LLM_TIMEOUT=30

# Set to true only if your OpenAI-compatible endpoint must use HTTP_PROXY/HTTPS_PROXY.
LLM_TRUST_ENV=false
LLM_STREAMING=true

# Qdrant memory storage
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=agent_memories
QDRANT_PREFER_GRPC=false

# Embedding
EMBEDDING_MODEL=./models/bge-m3
# auto detection order: CUDA -> Intel XPU -> Apple MPS -> CPU
EMBEDDING_DEVICE=auto
EMBEDDING_DIMENSION=1024
EMBEDDING_CONCURRENCY=1
EMBEDDING_BATCH_SIZE=32
EMBEDDING_SERVICE_URL=http://127.0.0.1:8001
EMBEDDING_TIMEOUT=30
EMBEDDING_TRUST_ENV=false

# Chainlit authentication and PostgreSQL persistence
# The same PostgreSQL database stores Chainlit UI history and LangGraph checkpoints.
CHAINLIT_DATABASE_URL=postgresql+asyncpg://memory_agent:memory_agent@localhost:5432/chainlit
CHAINLIT_AUTH_SECRET=your-generated-secret
CHAINLIT_AUTH_USERNAME=admin
CHAINLIT_AUTH_PASSWORD=change-this-password
CHAINLIT_AUTH_USER_ID=wenhao
LANGGRAPH_STRICT_MSGPACK=true

# Conversation context window
CONVERSATION_MESSAGE_WINDOW=20

# App defaults
APP_DEBUG=false

# Docker image user. Keep 1000 on most Linux machines, or set these to
# the output of `id -u` and `id -g` before building the image.
APP_UID=1000
APP_GID=1000
