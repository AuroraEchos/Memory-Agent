# LLM configuration
LLM_MODEL=mimo-v2.5-pro
LLM_API_KEY=replace-with-your-api-key
LLM_BASE_URL=https://api.example.com/v1
LLM_TEMPERATURE=0.7
LLM_MAX_COMPLETION_TOKENS=2048
LLM_TIMEOUT=30

# Set to true only if your OpenAI-compatible endpoint must use HTTP_PROXY/HTTPS_PROXY.
LLM_TRUST_ENV=false
LLM_STREAMING=true

# Qdrant memory storage
QDRANT_PATH=./qdrant_data
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=agent_memories
QDRANT_PREFER_GRPC=false

# Embedding
EMBEDDING_BACKEND=local
EMBEDDING_MODEL=./models/bge-m3
EMBEDDING_DEVICE=auto
EMBEDDING_DIMENSION=1024
EMBEDDING_CONCURRENCY=1
EMBEDDING_BATCH_SIZE=32
EMBEDDING_SERVICE_URL=
EMBEDDING_TIMEOUT=30
EMBEDDING_TRUST_ENV=false

# Docker image user. Keep 1000 on most Linux machines, or set these to
# the output of `id -u` and `id -g` before building the image.
APP_UID=1000
APP_GID=1000

# App defaults
DEFAULT_USER_ID=user_001
APP_DEBUG=false
